{
  "name": "zelda-botw-totk-guide-site",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vinext dev",
    "build": "vinext build && rm -rf dist/_appgen_meta && mkdir -p dist/_appgen_meta && if [ -f .openai/hosting.json ]; then cp .openai/hosting.json dist/_appgen_meta/appgarden.json; fi && if [ -d drizzle ]; then cp -R drizzle dist/_appgen_meta/drizzle; fi",
    "cf:dry-run": "npm run build && wrangler deploy --config dist/server/wrangler.json --dry-run",
    "cf:deploy": "npm run build && wrangler deploy --config dist/server/wrangler.json --minify",
    "start": "vinext start",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next --ignore-pattern worker-configuration.d.ts",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types --include-runtime --include-env false -c dist/server/wrangler.json",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.40.0",
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "25.9.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.27",
    "drizzle-kit": "0.31.10",
    "eslint": "10.4.1",
    "eslint-config-next": "16.2.7",
    "react-server-dom-webpack": "19.2.7",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "vinext": "0.0.55",
    "vite": "8.0.16",
    "wrangler": "4.98.0"
  },
  "type": "module"
}
